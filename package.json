{
  "name": "aura-platform",
  "description": "Aura — WhatsApp AI Agent SaaS Platform",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "lint:fix": "eslint --fix src/ server/ --ext .ts,.tsx",
    "format": "prettier --write src/ server/ *.ts *.json",
    "format:check": "prettier --check src/ server/",
    "test": "vitest run"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "firebase": "^12.13.0",
    "firebase-admin": "^13.10.0",
    "helmet": "^8.0.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pg": "^8.22.0",
    "pgvector": "^0.3.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-router-dom": "^7.18.0",
    "recharts": "^3.8.1",
    "ws": "^8.21.0",
    "zod": "^3.24.2",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@firebase/eslint-plugin-security-rules": "^0.0.2",
    "@tailwindcss/vite": "^4.1.14",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.25.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vitest": "^4.1.9"
  }
}
